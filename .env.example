# ISP Monitoring System Configuration

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=false
SERVER_WORKERS=4

# Database Configuration
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=isp-monitoring
INFLUXDB_BUCKET=network-metrics
INFLUXDB_TOKEN=your-influxdb-token

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Monitoring Configuration
MONITOR_INTERVAL=60
MONITOR_TIMEOUT=30
METRIC_RETENTION_DAYS=30

# Alert Configuration
ALERT_ENABLED=true
ALERT_EMAIL_ENABLED=true
ALERT_SLACK_ENABLED=false
ALERT_EMAIL_FROM=alerts@isp-monitor.local
ALERT_EMAIL_SMTP_SERVER=localhost
ALERT_EMAIL_SMTP_PORT=587

# Slack Integration (optional)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#network-alerts

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/monitoring.log
LOG_FORMAT=json
